# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=VeriLayer
APP_VERSION=0.1.0
DEBUG=false

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=verilayer
POSTGRES_USER=verilayer
POSTGRES_PASSWORD=verilayer_secret

# ─── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=verilayer-docs

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

# ─── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=30
GROQ_MAX_RETRIES=3

# ─── Jina Embeddings ──────────────────────────────────────────────────────────
JINA_API_KEY=your_jina_api_key_here
JINA_EMBED_MODEL=jina-embeddings-v3
JINA_EMBED_DIMENSIONS=1024

# ─── Langfuse Observability ───────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Agentic Pipeline ─────────────────────────────────────────────────────────
CONFIDENCE_VERIFIED_THRESHOLD=0.8
CONFIDENCE_PARTIAL_THRESHOLD=0.5
MAX_RETRIES=2
MAX_RETRIEVAL_DOCS=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
